        <mxCell id="12" value="&lt;b&gt;9. Agent &amp; 工作流&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#555555&quot;&gt;&lt;i&gt;Tool Use · MCP · 多Agent协作 · 可视化编排 · 记忆管理&lt;/i&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;AutoGen · CrewAI · LangGraph&lt;br&gt;Dify · Flowise · Langflow&lt;br&gt;Coze · n8n · OpenAI Agents SDK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;verticalAlign=top;fontSize=11;" vertex="1" parent="3">
